{
  "name": "simple-snake-game",
  "version": "1.4.0",
  "description": "Classic Snake game as a lightweight, offline, Manifest V3 Chrome extension.",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run coverage",
    "build": "node scripts/build.js",
    "package": "npm run build",
    "release": "npm run check && npm run build"
  },
  "keywords": [
    "snake",
    "game",
    "chrome-extension",
    "manifest-v3",
    "canvas",
    "javascript"
  ],
  "author": "Zhihua Lai (DoctorLai / justyy) <dr.zhihua.lai@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/doctorlai/snakegame#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/doctorlai/snakegame.git"
  },
  "bugs": {
    "url": "https://github.com/doctorlai/snakegame/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "archiver": "^8.0.0",
    "eslint": "^10.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "snake/js/engine.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 95,
        "functions": 100,
        "lines": 98,
        "statements": 98
      }
    }
  }
}
